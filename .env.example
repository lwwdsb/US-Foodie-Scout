# ── LLM ──────────────────────────────────────────────────────────────────────
# Get a free key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Fallback LLM (optional)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Yelp (restaurant photos) ──────────────────────────────────────────────────
# Get a free key at: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=your_yelp_api_key_here

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60

# ── Google (optional — mock data used when absent) ────────────────────────────
# GOOGLE_PLACES_API_KEY=your_google_places_key_here
# GOOGLE_MAPS_JS_KEY=your_google_maps_js_key_here

# ── XHS / RedNote real data ───────────────────────────────────────────────────
# Step 1: log in at xiaohongshu.com, open DevTools → Network → any request
#         → copy the full "Cookie:" header value and paste below
# Step 2: set XHS_USE_REAL=true
# Note: mock data with algorithm-computed scores is used by default
XHS_USE_REAL=false
XHS_COOKIE=
XHS_SEARCH_LOCATION=洛杉矶 SGV

# ── CORS (production) ─────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
