# ── LLM ───────────────────────────────────────────────────────────────────────
# Get a free key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Google Places (backend — server-side, IP-restricted) ──────────────────────
# Enable: Google Places API (New) in Cloud Console
# Restrict by: IP address (your server's IP, or unrestricted for development)
GOOGLE_API_KEY=your_google_places_api_key_here
GOOGLE_SOURCE=real   # "mock" to use bundled mock data without API calls

# ── XHS data source ───────────────────────────────────────────────────────────
# "bazhuayu" = read from data/xhs_notes.json (collected via 八爪鱼 desktop)
# "mock"     = use built-in mock data (no real XHS data needed)
XHS_SOURCE=bazhuayu
XHS_HIGH_THRESHOLD=70
XHS_SEARCH_LOCATION=洛杉矶 SGV

# ── Tavily (XHS web-search fallback for out-of-database restaurants) ──────────
# Get a free key at: https://tavily.com (1000 searches/month free)
TAVILY_API_KEY=

# ── Yelp (restaurant photos — optional) ──────────────────────────────────────
# Get a free key at: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Development: http://localhost:3000 is allowed by default
# Production: set to your Vercel domain
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
